# Environment variables for Taller Mecanico
# Copy this file to .env and fill in your values

DATABASE_URL="postgresql://${DB_USER:-taller_user}:${DB_PASSWORD:-taller_password}@${DB_HOST:-localhost}:5432/${DB_NAME:-taller_db}?schema=public"
NODE_ENV=development
PORT=3000
JWT_SECRET=change-this-secret-in-production-min-16-chars
CORS_ORIGIN=http://localhost:3043
LOG_LEVEL=info
API_VERSION=v1
